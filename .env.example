# ─────────────────────────────────────────────────────────────────────────────
# Root .env — single source of truth for the entire monorepo.
# Copy to .env and fill in values. Never commit .env.
#
# Keys are GENERIC here. `npm run env:sync` distributes them with the correct
# prefix per app:
#   apps/web        → NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY
#   apps/extension  → VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_WEB_APP_ORIGIN
#   apps/scraper    → SUPABASE_URL, SUPABASE_ANON_KEY (no prefix needed)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
SUPABASE_URL=                       # e.g. https://xxxx.supabase.co
SUPABASE_ANON_KEY=                  # safe to expose in the browser (anon/public)
SUPABASE_SERVICE_ROLE_KEY=          # server-only / scraper — NEVER bundle in frontend

# ── Web app origin ────────────────────────────────────────────────────────────
# The public URL of the web app. Used by the extension to open tabs and to
# validate postMessage origins. Change to http://localhost:3000 for local dev.
WEB_APP_ORIGIN=https://app.puckora.com

# ── Amazon SP-API ─────────────────────────────────────────────────────────────
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_REFRESH_TOKEN=
SP_MARKETPLACE_ID=              # optional; default: ATVPDKIKX0DER (US)

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Scraper (optional) ────────────────────────────────────────────────────────
PROXY_URL=                          # HTTP/SOCKS proxy; omit to disable
