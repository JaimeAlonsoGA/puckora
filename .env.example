# ─────────────────────────────────────────────────────────────────────────────
# Root .env — single source of truth for the entire monorepo.
# Copy to .env and fill in values. Never commit .env.
#
# Keys are GENERIC here. `npm run env:sync` distributes them with the correct
# prefix per app:
#   apps/web        → NEXT_PUBLIC_SUPABASE_URL, NEXT_PUBLIC_SUPABASE_ANON_KEY, DATABASE_URL
#   apps/extension  → VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_WEB_APP_ORIGIN
#   apps/scraper    → SUPABASE_URL, SUPABASE_ANON_KEY, DATABASE_URL (no prefix needed)
#
# Data storage split:
#   Supabase   → auth (users), scrape_jobs (Realtime), public.users profile
#   Fly.io PG  → product catalog, categories, keywords, GS data (Drizzle via DATABASE_URL)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase (auth + scrape_jobs + user profiles) ─────────────────────────────
SUPABASE_URL=                       # e.g. https://xxxx.supabase.co
SUPABASE_ANON_KEY=                  # safe to expose in the browser (anon/public)
SUPABASE_SERVICE_ROLE_KEY=          # server-only / scraper — NEVER bundle in frontend

# ── Fly.io Postgres (product catalog, categories, keywords) ───────────────────
DATABASE_URL=                       # postgres://user:pass@host:port/dbname?sslmode=require
                                    # Used by apps/web (integrations/flyio/client.ts) and
                                    # apps/scraper (shared/db.ts). Never sent to the extension.
DATABASE_PROXY_URL=                 # optional local Fly proxy, e.g. postgres://user:pass@127.0.0.1:15432/db?sslmode=disable

# ── Web app origin ────────────────────────────────────────────────────────────
# The public URL of the web app. Used by the extension to open tabs and to
# validate postMessage origins. Change to http://localhost:3000 for local dev.
WEB_APP_ORIGIN=https://app.puckora.com

# ── Amazon SP-API ─────────────────────────────────────────────────────────────
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_REFRESH_TOKEN=
SP_MARKETPLACE_ID=              # optional; default: ATVPDKIKX0DER (US)

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Vectors ───────────────────────────────────────────────────────────────────
# OpenAI is the primary embedding provider. To fall back to Ollama later,
# change VECTOR_EMBEDDING_PROVIDER=ollama, adjust model/dimensions, then rebuild.
VECTOR_DATABASE_URL=postgresql://127.0.0.1:5432/puckora_vectors
VECTOR_EMBEDDING_PROVIDER=openai
VECTOR_EMBEDDING_MODEL=text-embedding-3-small
VECTOR_EMBEDDING_DIMENSIONS=1536
VECTOR_OLLAMA_BASE_URL=http://127.0.0.1:11434
VECTOR_SYNC_BATCH_SIZE=25
VECTOR_SYNC_POLL_MS=30000
VECTOR_SYNC_STATE_FILE=
VECTOR_OPENAI_BATCH_SIZE=5000
VECTOR_OPENAI_BATCH_POLL_MS=300000
VECTOR_OPENAI_BATCH_STATE_FILE=
VECTOR_MIN_SCORE=0.5
VECTOR_QUERY_LIMIT=6

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Scraper ───────────────────────────────────────────────────────────────────
PROXY_URL=                          # HTTP/SOCKS proxy for Playwright; omit to disable
SUPABASE_PASSWORD=                  # Supabase DB password — only needed for scripts/migrate-to-flyio.sh
