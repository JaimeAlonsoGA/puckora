# ─────────────────────────────────────────────────────────────────────────────
# Root .env — single source of truth for the entire monorepo.
# Copy to .env and fill in values. Never commit .env.
#
# Used by:
#   apps/web     — Next.js (loaded in next.config.ts)
#   apps/scraper — Node.js (loaded in config.ts)
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: Supabase dashboard → Project Settings → API
# Or run `supabase start` locally and copy from its output.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=          # server-only / scraper

# ── Amazon SP-API ─────────────────────────────────────────────────────────────
# Create an SP-API app at: https://sellercentral.amazon.com/apps/manage

SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_REFRESH_TOKEN=
SP_MARKETPLACE_ID=              # optional; default: ATVPDKIKX0DER (US)

# ── Apify ─────────────────────────────────────────────────────────────────────
APIFY_API_TOKEN=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Scraper (optional) ────────────────────────────────────────────────────────
PROXY_URL=                          # HTTP/SOCKS proxy; omit to disable
