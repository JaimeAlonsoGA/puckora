{
    "name": "@puckora/extension",
    "version": "0.1.0",
    "private": true,
    "scripts": {
        "build": "vite build && vite build --config vite.scripts.ts && cp manifest.json dist/manifest.json",
        "dev": "concurrently \"vite build --watch\" \"vite build --watch --config vite.scripts.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "dependencies": {
        "@puckora/scraper-core": "*",
        "@puckora/types": "*",
        "@puckora/ui": "*",
        "@puckora/utils": "*",
        "@supabase/supabase-js": "^2.39.0",
        "@tanstack/react-query": "^5.0.0",
        "i18next": "^24.0.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "react-i18next": "^15.0.0",
        "zustand": "^5.0.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.0",
        "@types/chrome": "^0.0.300",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.0.0",
        "concurrently": "^9.0.0",
        "tailwindcss": "^4.1.0",
        "typescript": "^5.8.2",
        "vite": "^6.0.0"
    }
}